# =============================================
# Axiom Backend (FastAPI) — Environment Variables
# =============================================

# MongoDB
# Local dev: mongodb://127.0.0.1:27017
# Produção: use MongoDB Atlas (mongodb+srv://user:pass@cluster.xxxx.mongodb.net)
MONGO_URL=mongodb://127.0.0.1:27017
DB_NAME=axiom_db

# JWT — troque em produção por um valor aleatório forte (>= 32 chars)
JWT_SECRET=change-me-in-production-please-use-a-long-random-string

# URL pública do frontend (Vercel), usada para CORS
FRONTEND_URL=http://localhost:3000

# Seed do admin (criado no primeiro start se não existir)
ADMIN_EMAIL=adminpalmilha
ADMIN_PASSWORD=admin@123

# --- Ponte para o serviço WhatsApp (rodando fora do Vercel, no servidor) ---
# URL interna onde o whatsapp-service está exposto
WHATSAPP_SERVICE_URL=http://127.0.0.1:3001
# Token compartilhado entre backend e whatsapp-service (obrigatório em produção)
WHATSAPP_SERVICE_TOKEN=troque-este-token-em-producao

# Cookies seguros em produção (true quando servir por HTTPS)
COOKIE_SECURE=false
# domain de cookie opcional (ex: .meudominio.com.br) — deixe vazio em dev
COOKIE_DOMAIN=

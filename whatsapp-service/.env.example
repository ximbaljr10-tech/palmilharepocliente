# Porta e bind do serviço WhatsApp interno.
# Em produção mantenha em 127.0.0.1 e exponha apenas via reverse-proxy/tunnel/VPN se necessário.
PORT=3001
BIND=127.0.0.1

# Token compartilhado com o backend FastAPI (obrigatório em produção).
# O backend envia esse valor em X-Internal-Token.
INTERNAL_TOKEN=troque-este-token-em-producao

# Diretório persistente de credenciais Baileys (NÃO apagar em produção).
AUTH_DIR=./auth_info_baileys

# Opcional: origem autorizada para CORS direto (se for chamado do browser).
# Deixe vazio em produção; o fluxo oficial é backend -> whatsapp-service.
CORS_ORIGIN=

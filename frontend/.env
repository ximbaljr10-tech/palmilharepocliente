# ===================================================
# Flags de build do Create React App (frontend)
# ===================================================
# IMPORTANTE: NAO declare REACT_APP_BACKEND_URL aqui!
# A URL do backend esta HARDCODED em src/config.js.
# Se voce colocar REACT_APP_BACKEND_URL aqui, o CRA
# vai substituir a variavel durante o build e pode
# quebrar producao (ex: Vercel pegando "localhost:8001").
# ===================================================

GENERATE_SOURCEMAP=false
CI=false

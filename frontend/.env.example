# URL pública do backend FastAPI (deploy separado em Railway/Render/Fly.io)
# Exemplo: https://seu-backend.up.railway.app
REACT_APP_BACKEND_URL=https://seu-backend.exemplo.com

# Desativa overlay de erro do CRA em produção (opcional)
GENERATE_SOURCEMAP=false

# Ignora warnings de peer deps durante o build no Vercel
CI=false

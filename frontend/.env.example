# URL pública do backend FastAPI (deploy separado — Railway/Render/Fly.io/seu servidor).
# Exemplo: https://api.palmilha.seudominio.com
REACT_APP_BACKEND_URL=https://seu-backend.exemplo.com

# Desativa sourcemaps em produção (recomendado).
GENERATE_SOURCEMAP=false

# Permite o build passar mesmo com warnings (importante para CI/Vercel).
CI=false

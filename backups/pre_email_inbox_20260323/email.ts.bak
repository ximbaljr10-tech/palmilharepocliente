// ====== SEND EMAIL ======

export async function sendOrderEmail(type: 'received' | 'paid' | 'shipped' | 'delivered', order: any, trackingCode?: string): Promise<boolean> {
  try {
    const transporter = getTransporter()
    if (!transporter) {
      console.log(`[EMAIL] SMTP não configurado. Email "${type}" para ${order.customer_email} não enviado.`)
      return false
    }

    let emailData: { subject: string; html: string }
    switch (type) {
      case 'received': emailData = emailPedidoRecebido(order); break
      case 'paid': emailData = emailPagamentoConfirmado(order); break
      case 'shipped': emailData = emailPedidoEnviado(order, trackingCode || ''); break
      case 'delivered': emailData = emailPedidoEntregue(order); break
      default: return false
    }

    await transporter.sendMail({
      from: SMTP_FROM,
      to: order.customer_email,
      subject: emailData.subject,
      html: emailData.html,
    })

    console.log(`[EMAIL] "${type}" enviado para ${order.customer_email} (Pedido #${order.display_id || order.id})`)
    return true
  } catch (error: any) {
    console.error(`[EMAIL] Erro ao enviar "${type}" para ${order.customer_email}:`, error.message)
    return false
  }
}

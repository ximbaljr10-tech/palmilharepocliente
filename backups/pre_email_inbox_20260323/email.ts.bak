    html: baseTemplate('Pedido Entregue! 🎣', `
      <p style="color:#52525b;line-height:1.6;">
        Olá, <strong>${order.customer_name}</strong>!
      </p>
      <p style="color:#52525b;line-height:1.6;">
        Seu pedido <strong>#${order.display_id || order.id}</strong> foi entregue com sucesso!
      </p>
      <div style="background:#d1fae5;border:1px solid #34d399;border-radius:12px;padding:20px;text-align:center;margin:16px 0;">
        <p style="color:#065f46;font-size:18px;font-weight:bold;margin:0;">Obrigado por comprar com a gente! 🦈</p>
      </div>
      <p style="color:#52525b;line-height:1.6;font-size:14px;">
